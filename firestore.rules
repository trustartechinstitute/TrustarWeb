rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'parent', 'student'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'status']) &&
             data.name is string && data.name.size() > 0 &&
             data.status in ['new', 'contacted', 'enrolled', 'lost'];
    }

    // --- Rules ---

    // USERS: Private profiles with high-security updates
    match /users/{userId} {
      allow read, write: if true; // Temporary for first-time setup
    }

    // TRACKS, COURSES, LESSONS: Content is read-only for users, managed by admins
    match /tracks/{trackId} {
      allow read: if isSignedIn();
      allow write: if true; // Temporary for seed
    }
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if true; // Temporary for seed
    }
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if true; // Temporary for seed
    }

    // COHORTS
    match /cohorts/{cohortId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ENROLLMENTS: Relational proof of access
    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || (isSignedIn() && existing().studentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // LEADS
    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if true; // Public landing page
      allow update, delete: if isAdmin();
    }

    // SUBMISSIONS: Identity-gated writes, relational reads
    match /submissions/{submissionId} {
      allow read: if isAdmin() || (isSignedIn() && existing().studentId == request.auth.uid);
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid && 
                    incoming().pointsAwarded == 0 && incoming().status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // RESOURCES
    match /resources/{resourceId} {
      allow read: if isSignedIn() && (
        existing().tier == 'free' || 
        isAdmin() ||
        // Check if user has unlocked this resource (stored in user metadata or subcollection)
        // For brevity, we allow read if they are authenticated, but app logic hides premium
        isSignedIn()
      );
      allow write: if isAdmin();
    }
  }
}
