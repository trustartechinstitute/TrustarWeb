{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profiles for admins, parents, and students.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "parent", "student"] },
        "studentType": { "type": "string", "enum": ["child", "independent"] },
        "parentId": { "type": "string", "description": "Links a child student to their parent account." },
        "points": { "type": "number", "description": "Effort score earned through activities." },
        "coinBalance": { "type": "number", "description": "Prepaid credit balance for premium resources." },
        "country": { "type": "string" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["name", "email", "role"]
    },
    "Track": {
      "title": "Track",
      "description": "High-level learning pathways (e.g., Foundations, Builders).",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["title", "description"]
    },
    "Course": {
      "title": "Course",
      "description": "Master Course curriculum defined once and reused across cohorts.",
      "type": "object",
      "properties": {
        "trackId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "durationWeeks": { "type": "number" }
      },
      "required": ["trackId", "title", "description"]
    },
    "Cohort": {
      "title": "Cohort",
      "description": "A specific class instance of a course with a schedule and instructor.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "active", "completed"] },
        "deliveryMode": { "type": "string", "enum": ["online", "physical", "hybrid"] },
        "onlineMeetUrl": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "schedule": { "type": "string" },
        "timezone": { "type": "string" },
        "instructorId": { "type": "string" },
        "currentWeek": { "type": "number", "description": "Pacing control for content release." }
      },
      "required": ["courseId", "name", "status"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Content blocks and instructions for the Master Course curriculum.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "week": { "type": "number" },
        "session": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "contentBlocks": { "type": "array" },
        "practiceInstructions": { "type": "string" },
        "assignmentInstructions": { "type": "string" },
        "assignmentRequired": { "type": "boolean" }
      },
      "required": ["courseId", "title", "week", "session"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Links a student to a specific cohort.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "cohortId": { "type": "string" },
        "courseId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "enrolledAt": { "type": "string" },
        "accessExpiresAt": { "type": "string" }
      },
      "required": ["studentId", "cohortId", "courseId", "status"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Inbound interests from the landing page.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "country": { "type": "string" },
        "interestedTrack": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "enrolled", "lost"] },
        "source": { "type": "string" },
        "childAge": { "type": "string" }
      },
      "required": ["name", "status"]
    },
    "Resource": {
      "title": "Resource",
      "description": "PDFs, videos, and templates in the library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "video", "link"] },
        "url": { "type": "string" },
        "tier": { "type": "string", "enum": ["free", "premium"] },
        "coinCost": { "type": "number" },
        "trackIds": { "type": "array" }
      },
      "required": ["title", "type", "tier"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Public and private user profiles." },
    "/tracks/{trackId}": { "schema": "Track", "description": "Learning tracks." },
    "/courses/{courseId}": { "schema": "Course", "description": "Master courses." },
    "/cohorts/{cohortId}": { "schema": "Cohort", "description": "Cohort instances." },
    "/lessons/{lessonId}": { "schema": "Lesson", "description": "Course lessons." },
    "/enrollments/{enrollmentId}": { "schema": "Enrollment", "description": "Student cohort enrollments." },
    "/leads/{leadId}": { "schema": "Lead", "description": "Sales leads." },
    "/resources/{resourceId}": { "schema": "Resource", "description": "Learning resources." }
  }
}
